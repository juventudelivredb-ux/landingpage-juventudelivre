---
/* Transparency Section — "100% Independentes" — Double Bezel Cards */
---

<section
  id="transparencia"
  class="relative py-28 md:py-40 overflow-hidden bg-[#0a0a0a]"
  aria-labelledby="transparency-heading"
>
  <!-- Background grids and outline watermarks -->
  <div class="absolute inset-0 opacity-[0.02] bg-[linear-gradient(to_right,#ffffff_1px,transparent_1px),linear-gradient(to_bottom,#ffffff_1px,transparent_1px)] bg-[size:30px_30px]" aria-hidden="true"></div>
  
  <!-- Massive Editorial Outline Text (Watermark behind text columns) -->
  <div class="absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none select-none font-heading text-[12vw] leading-none text-white/[0.01] uppercase tracking-[0.2em] whitespace-nowrap z-0" style="-webkit-text-stroke: 1.5px rgba(255,255,255,0.03);" aria-hidden="true">
    INDEPENDENTE
  </div>

  <div
    class="absolute inset-0 pointer-events-none"
    style="background:
      radial-gradient(ellipse at 20% 50%, rgba(230,192,0,0.03) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 50%, rgba(230,192,0,0.02) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <!-- Decorative accent borders -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent" aria-hidden="true"></div>

  <!-- Decorative lamparina watermark -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-[0.015] pointer-events-none" aria-hidden="true">
    <img src="/logo-lamparina.webp" alt="" class="w-[500px] h-auto" width="500" height="500" aria-hidden="true" />
  </div>

  <div class="section-container relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-12 items-center">
      
      <!-- Text content: 5 columns -->
      <div class="lg:col-span-5 relative z-10">
        <div class="reveal" data-reveal>
          <span class="inline-block px-3 py-1 border border-accent/20 rounded-full text-[10px] font-semibold tracking-[0.2em] uppercase text-accent bg-accent/5 mb-6">
            Transparência
          </span>
        </div>

        <h2
          id="transparency-heading"
          class="reveal reveal-d1 font-heading text-5xl sm:text-6xl text-white leading-[0.95] mb-6"
          data-reveal
        >
          100%<br />
          <span class="text-accent">INDEPENDENTES</span>
        </h2>
        <div class="reveal reveal-d2 accent-line mb-8" data-reveal aria-hidden="true"></div>

        <p class="reveal reveal-d2 text-text-muted text-base md:text-[1.0625rem] leading-[1.75] mb-8" data-reveal>
          Não usamos dinheiro público ou partidário. Nossa força vem do apoio voluntário de indivíduos
          e parceiros internacionais que acreditam no livre mercado e na liberdade de expressão, como a
          <strong class="text-white font-medium">Students For Liberty (SFL)</strong> e a
          <strong class="text-white font-medium">Atlas Network</strong>.
        </p>

        <!-- Shield Icon Badge (Visual Highlight) -->
        <div class="reveal reveal-d3 mt-10 flex items-center gap-5" data-reveal>
          <div class="relative flex items-center justify-center w-14 h-14 rounded-2xl bg-accent/5 border border-accent/20 shadow-[0_0_20px_rgba(230,192,0,0.1)]">
            <svg class="w-7 h-7 text-accent relative z-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="text-xs uppercase tracking-wider text-accent font-semibold">Selo de Auditoria</span>
            <span class="text-xs text-text-subtle mt-0.5">Livre de verbas estatais ou partidárias</span>
          </div>
        </div>
      </div>

      <!-- Stat cards: Bento Grid - 7 columns -->
      <div class="lg:col-span-7">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          
          <!-- Card 1 -->
          <div class="reveal" data-reveal>
            <div class="card-shell transparency-card h-full">
              <div class="card-core p-8 h-full flex flex-col justify-between">
                <div class="icon-box-wrapper mb-6 flex items-center justify-center w-10 h-10 rounded-lg bg-accent/5 border border-accent/15">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading text-4xl text-white mb-2">R$ 0</p>
                  <p class="text-sm text-text-muted">Dinheiro Público</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="reveal reveal-d1" data-reveal>
            <div class="card-shell transparency-card h-full">
              <div class="card-core p-8 h-full flex flex-col justify-between">
                <div class="icon-box-wrapper mb-6 flex items-center justify-center w-10 h-10 rounded-lg bg-accent/5 border border-accent/15">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading text-4xl text-white mb-2">100%</p>
                  <p class="text-sm text-text-muted">Voluntário</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="reveal reveal-d2" data-reveal>
            <div class="card-shell transparency-card h-full">
              <div class="card-core p-8 h-full flex flex-col justify-between">
                <div class="icon-box-wrapper mb-6 flex items-center justify-center w-10 h-10 rounded-lg bg-accent/5 border border-accent/15">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9 9 0 0 1 3 12c0-1.47.353-2.856.978-4.082" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading text-4xl text-white mb-2">Global</p>
                  <p class="text-sm text-text-muted">Rede Internacional</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Card 4 -->
          <div class="reveal reveal-d3" data-reveal>
            <div class="card-shell transparency-card h-full">
              <div class="card-core p-8 h-full flex flex-col justify-between">
                <div class="icon-box-wrapper mb-6 flex items-center justify-center w-10 h-10 rounded-lg bg-accent/5 border border-accent/15">
                  <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0 1 16.5 7.605" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading text-4xl text-white mb-2">Aberta</p>
                  <p class="text-sm text-text-muted">Prestação de Contas</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Minimalismo Brutalista Premium para os Bento Cards */
  .transparency-card {
    border-color: rgba(255, 255, 255, 0.06) !important;
    transition: 
      border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  /* Elevação sutil com borda dourada elegante no hover */
  .transparency-card:hover {
    border-color: rgba(230, 192, 0, 0.35) !important;
    transform: translateY(-4px);
    box-shadow: 
      0 12px 30px rgba(0, 0, 0, 0.5),
      0 0 15px rgba(230, 192, 0, 0.1) !important;
  }
</style>
