---
/* Footer — High-end editorial aesthetic */
const currentYear = new Date().getFullYear();
---

<footer
  class="relative border-t border-white/5 bg-bg py-24 overflow-hidden"
  role="contentinfo"
>
  <!-- Subtle lamparina watermark -->
  <div
    class="absolute left-1/2 -translate-x-1/2 -bottom-32 opacity-[0.015] pointer-events-none"
    aria-hidden="true"
  >
    <img src="/logo-lamparina.webp" alt="" class="w-[600px] h-auto" width="600" height="600" aria-hidden="true" loading="lazy" />
  </div>

  <div class="section-container relative z-10">
    <!-- Main Footer Grid: Split left heavy, right lists -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 mb-24">
      <!-- Brand & Info (Left - 6 cols) -->
      <div class="lg:col-span-6 flex flex-col items-start gap-8">
        <a
          href="#"
          class="flex items-center"
          aria-label="Juventude Livre — Início"
        >
          <img
            src="/logo-juventude-livre-branca.webp"
            alt="Juventude Livre"
            class="h-12 w-auto hover:opacity-80 transition-opacity duration-300"
            width="192"
            height="48"
            loading="lazy"
          />
        </a>
        <p class="text-base text-text-muted leading-relaxed max-w-sm">
          O principal movimento político estudantil liberal do Brasil. A única
          força fora da bolha.
        </p>
        <div
          class="flex items-center gap-2 text-sm text-text-subtle font-medium mt-4"
        >
          <svg
            class="w-4 h-4 text-accent"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
            ></path>
          </svg>
          Sede em Brasília, Brasil
        </div>
      </div>

      <!-- Navigation Links (Middle - 3 cols) -->
      <nav
        class="lg:col-span-3 flex flex-col items-start gap-5"
        aria-label="Links rápidos"
      >
        <span
          class="text-xs font-semibold uppercase tracking-[0.2em] text-text-subtle mb-2"
          >Navegação</span
        >
        <a
          href="#sobre"
          class="text-[0.9375rem] text-text-muted hover:text-accent transition-colors duration-300"
          >Sobre Nós</a
        >
        <a
          href="#historia"
          class="text-[0.9375rem] text-text-muted hover:text-accent transition-colors duration-300"
          >Nossa História</a
        >
        <a
          href="#transparencia"
          class="text-[0.9375rem] text-text-muted hover:text-accent transition-colors duration-300"
          >Transparência</a
        >
    
        >
      </nav>

      <!-- Social Links (Right - 3 cols) -->
      <div class="lg:col-span-3 flex flex-col items-start gap-5">
        <span
          class="text-xs font-semibold uppercase tracking-[0.2em] text-text-subtle mb-2"
          >Redes Sociais</span
        >

        <!-- Button-in-button style social links -->
        <a
          href="https://twitter.com/JuventudeLivre_"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 text-[0.9375rem] text-text-muted hover:text-white transition-colors duration-300"
        >
          <span
            class="w-8 h-8 rounded-full bg-white/5 border border-white/5 flex items-center justify-center transition-all duration-300 group-hover:border-accent/30 group-hover:bg-accent/10"
          >
            <svg
              class="w-3.5 h-3.5 group-hover:text-accent transition-colors"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
          </span>
          Twitter / X
        </a>

        <a
          href="https://www.instagram.com/juventudelivrebr"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 text-[0.9375rem] text-text-muted hover:text-white transition-colors duration-300"
        >
          <span
            class="w-8 h-8 rounded-full bg-white/5 border border-white/5 flex items-center justify-center transition-all duration-300 group-hover:border-accent/30 group-hover:bg-accent/10"
          >
            <svg
              class="w-3.5 h-3.5 group-hover:text-accent transition-colors"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
              ></path></svg
            >
          </span>
          Instagram
        </a>

        <a
          href="https://youtube.com/@JuventudeLivre"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 text-[0.9375rem] text-text-muted hover:text-white transition-colors duration-300"
        >
          <span
            class="w-8 h-8 rounded-full bg-white/5 border border-white/5 flex items-center justify-center transition-all duration-300 group-hover:border-accent/30 group-hover:bg-accent/10"
          >
            <svg
              class="w-3.5 h-3.5 group-hover:text-accent transition-colors"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              ><path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path></svg
            >
          </span>
          YouTube
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4 border-t border-white/5"
    >
      <p class="text-xs text-text-subtle">
        &copy; {currentYear} Juventude Livre. Todos os direitos reservados.
      </p>
      <p class="text-xs text-text-subtle font-medium">
        Feito com <span class="text-accent px-1">♥</span> pela juventude que acredita
        na liberdade.
      </p>
    </div>
  </div>
</footer>
