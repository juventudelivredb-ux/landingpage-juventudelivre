---
/* Hero Section — Scroll-controlled video + cinematic text overlay */
---

<section id="inicio" class="hero-scroll-wrapper" aria-labelledby="hero-heading">
  <div class="hero-sticky">
    <!-- Video background -->
    <video
      id="hero-video"
      class="hero-video"
      src="/hero-video.mp4"
      poster="/hero-poster.webp"
      muted
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/hero-video.webm" type="video/webm" />
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>

    <!-- Layered overlays for cinematic depth -->
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-vignette" aria-hidden="true"></div>

    <!-- Content — bottom-left editorial placement -->
    <div class="hero-content section-container">
      <div class="hero-content-inner">
        <!-- Eyebrow tag -->
        <span class="hero-eyebrow">
          Movimento Estudantil Liberal
        </span>

        <!-- H1 — massive display -->
        <h1
          id="hero-heading"
          class="font-heading hero-h1"
        >
          FAREMOS<br />
          <span class="text-accent hero-h1-accent">HISTÓRIA!</span>
        </h1>

        <!-- Subtitle -->
        <p class="hero-subtitle">
          Somos a <strong class="text-white font-semibold">Juventude Livre</strong>. O principal movimento
          político estudantil liberal do Brasil, lutando por liberdade e representatividade dentro das
          escolas e universidades.
        </p>

        <!-- CTA — button-in-button -->
        <a
          id="junte-se"
          href="http://localhost:5173/cadastro"
          target="_blank"
          rel="noopener noreferrer"
          class="hero-cta group"
        >
          <span>Faça parte dos mais de 6 mil membros</span>
          <span class="hero-cta-icon group-hover:translate-x-0.5 group-hover:-translate-y-px group-hover:scale-105">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </span>
        </a>
      </div>

      <!-- Scroll hint — right side -->
      <div class="hero-scroll-hint" aria-hidden="true">
        <div class="hero-scroll-line"></div>
        <span class="text-[10px] text-white/30 tracking-[0.2em] uppercase mt-2">Scroll</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-scroll-wrapper {
    position: relative;
    height: 400vh;
  }

  .hero-sticky {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transform: scale(1.4);
    transform-origin: center 30%;
  }

  /* Multi-layer overlay for cinematic grade */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.3) 0%,
      rgba(10, 10, 10, 0.15) 40%,
      rgba(10, 10, 10, 0.7) 75%,
      rgba(10, 10, 10, 0.92) 100%
    );
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 50%,
      rgba(10, 10, 10, 0.5) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 100%;
    padding-bottom: 5rem;
  }

  .hero-content-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 680px;
  }

  /* Eyebrow pill */
  .hero-eyebrow {
    display: inline-block;
    padding: 0.375rem 1rem;
    border: 1px solid rgba(230, 192, 0, 0.25);
    border-radius: 9999px;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    backdrop-filter: blur(8px);
    background: rgba(230, 192, 0, 0.05);
  }

  /* Display heading */
  .hero-h1 {
    font-size: clamp(3.5rem, 10vw, 9rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .hero-h1-accent {
    text-shadow: 0 0 80px rgba(230, 192, 0, 0.15);
  }

  .hero-subtitle {
    max-width: 520px;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 2.5rem;
  }

  /* CTA — button-in-button */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 0.875rem 0.875rem 1.75rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 9999px;
    transition: all 0.5s var(--ease-spring);
    box-shadow: 0 0 40px rgba(230, 192, 0, 0.15);
  }

  .hero-cta:hover {
    background: var(--color-accent-hover);
    box-shadow: 0 0 60px rgba(230, 192, 0, 0.25);
    transform: translateY(-1px);
  }

  .hero-cta:active {
    transform: scale(0.97);
  }

  .hero-cta-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: rgba(0, 0, 0, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.5s var(--ease-spring);
  }

  /* Scroll indicator — animated line */
  .hero-scroll-hint {
    display: none;
    flex-direction: column;
    align-items: center;
  }

  .hero-scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.2), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (min-width: 768px) {
    .hero-scroll-hint { display: flex; }
    .hero-subtitle { font-size: 1.0625rem; }
  }

  @media (max-width: 767px) {
    .hero-content {
      align-items: flex-end;
      padding-bottom: 3rem;
    }
    .hero-content-inner {
      align-items: flex-start;
    }
  }
</style>

<script>
  const video = document.getElementById("hero-video") as HTMLVideoElement | null;
  const wrapper = document.querySelector(".hero-scroll-wrapper") as HTMLElement | null;

  if (video && wrapper) {
    let targetX = 0;
    let targetY = 0;
    let currentX = 0;
    let currentY = 0;
    let scrollProgress = 0;

    const calculateScroll = () => {
      const rect = wrapper.getBoundingClientRect();
      const scrollableDistance = wrapper.offsetHeight - window.innerHeight;
      scrollProgress = Math.min(Math.max(-rect.top / scrollableDistance, 0), 1);
    };
    calculateScroll();

    window.addEventListener("scroll", calculateScroll, { passive: true });

    window.addEventListener("mousemove", (e) => {
      const x = (e.clientX / window.innerWidth) * 2 - 1;
      const y = (e.clientY / window.innerHeight) * 2 - 1;
      targetX = x * -40; // 40px máximo de deslocamento parallax
      targetY = y * -40;
    });

    const onReady = () => {
      const duration = video.duration;
      let lastTime = -1;
      
      const renderLoop = () => {
        if (duration && !isNaN(duration)) {
          const targetTime = scrollProgress * duration;
          // Evita updates redundantes para melhor performance
          if (Math.abs(targetTime - lastTime) > 0.01) {
            video.currentTime = targetTime;
            lastTime = targetTime;
          }
        }

        // Interpolação suave para o movimento do mouse
        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;
        
        video.style.transform = `scale(1.4) translate(${currentX}px, ${currentY}px)`;
        
        requestAnimationFrame(renderLoop);
      };

      requestAnimationFrame(renderLoop);
    };

    if (video.readyState >= 1) {
      onReady();
    } else {
      video.addEventListener("loadedmetadata", onReady);
    }
  }
</script>
